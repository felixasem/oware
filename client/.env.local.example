# Copy this file to ".env.local" ONLY when deploying multiplayer.
#
# For the single-player static build on Hostinger, do NOT create .env.local —
# leave multiplayer disabled (the defaults in next.config.js handle that).
#
# To enable multiplayer, set your live backend URL (must be HTTPS) and the flag,
# then run `npm run build`:

NEXT_PUBLIC_SERVER_URL=https://your-backend-url.onrender.com
NEXT_PUBLIC_ENABLE_MULTIPLAYER=true
